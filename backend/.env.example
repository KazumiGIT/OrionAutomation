# ─── Gemini AI Key ────────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
# Server-side only — powers the chatbot proxy (/api/chat) and blog generator.
GEMINI_KEY=your_gemini_api_key_here

# ─── Supabase (Frontend - Public) ─────────────────────────────────────────────
# Get from: Supabase Dashboard -> Settings -> API
# Project URL  (e.g. https://abcxyzabc.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon / Public Key (safe to use on frontend)
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# ─── Supabase (Backend Only - Secret!) ────────────────────────────────────────
# Service Role Key - NEVER commit this, NEVER expose to frontend
# Get from: Supabase Dashboard -> Settings -> API -> service_role
SUPABASE_SERVICE_KEY=your_service_role_key_here
